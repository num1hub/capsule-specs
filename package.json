{
  "name": "@num1hub/capsule-specs",
  "version": "0.1.0",
  "private": false,
  "description": "Public specs, schemas, examples, and validator-facing contracts for N1Hub and CapsuleOS.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/num1hub/capsule-specs.git"
  },
  "homepage": "https://github.com/num1hub/capsule-specs",
  "bugs": {
    "url": "https://github.com/num1hub/capsule-specs/issues"
  },
  "main": "./dist/projections/index.js",
  "types": "./dist/projections/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/projections/index.d.ts",
      "require": "./dist/projections/index.js",
      "default": "./dist/projections/index.js"
    },
    "./typescript": {
      "types": "./dist/projections/typescript/index.d.ts",
      "require": "./dist/projections/typescript/index.js",
      "default": "./dist/projections/typescript/index.js"
    },
    "./typescript/capsule": {
      "types": "./dist/projections/typescript/capsule.d.ts",
      "require": "./dist/projections/typescript/capsule.js",
      "default": "./dist/projections/typescript/capsule.js"
    },
    "./typescript/client-recipe-index": {
      "types": "./dist/projections/typescript/client-recipe-index.d.ts",
      "require": "./dist/projections/typescript/client-recipe-index.js",
      "default": "./dist/projections/typescript/client-recipe-index.js"
    },
    "./typescript/validator-envelope-families": {
      "types": "./dist/projections/typescript/validator-envelope-families.d.ts",
      "require": "./dist/projections/typescript/validator-envelope-families.js",
      "default": "./dist/projections/typescript/validator-envelope-families.js"
    },
    "./typescript/validator-routes": {
      "types": "./dist/projections/typescript/validator-routes.d.ts",
      "require": "./dist/projections/typescript/validator-routes.js",
      "default": "./dist/projections/typescript/validator-routes.js"
    },
    "./typescript/validator-api": {
      "types": "./dist/projections/typescript/validator-api.d.ts",
      "require": "./dist/projections/typescript/validator-api.js",
      "default": "./dist/projections/typescript/validator-api.js"
    },
    "./zod": {
      "types": "./dist/projections/zod/index.d.ts",
      "require": "./dist/projections/zod/index.js",
      "default": "./dist/projections/zod/index.js"
    },
    "./zod/capsule": {
      "types": "./dist/projections/zod/capsule.d.ts",
      "require": "./dist/projections/zod/capsule.js",
      "default": "./dist/projections/zod/capsule.js"
    },
    "./zod/validator-api": {
      "types": "./dist/projections/zod/validator-api.d.ts",
      "require": "./dist/projections/zod/validator-api.js",
      "default": "./dist/projections/zod/validator-api.js"
    },
    "./schemas/*": "./schemas/*",
    "./openapi/*": "./openapi/*",
    "./references/*": "./references/*",
    "./capsules/*": "./capsules/*",
    "./examples/*": "./examples/*",
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md",
    "CITATION.cff",
    "QUICKSTART.md",
    "ONBOARDING.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "SUPPORT.md",
    "GOVERNANCE.md",
    "MAINTAINERS.md",
    "ROADMAP.md",
    "RELEASING.md",
    "VERSIONING.md",
    "OPEN_CORE_PLAN.md",
    "SOURCE_MANIFEST.json",
    "PUBLIC_*.json",
    "PUBLIC_RELEASE_REVIEW.md",
    "docs/",
    "schemas/",
    "openapi/",
    "references/",
    "examples/",
    "capsules/",
    "projections/",
    "dist/"
  ],
  "keywords": [
    "n1hub",
    "capsuleos",
    "schema",
    "typescript",
    "validator",
    "open-core",
    "knowledge-graph",
    "specs",
    "zod"
  ],
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "audit:public-surface": "node scripts/audit-public-surface.js",
    "build:projections": "tsc -p tsconfig.build.json",
    "build:schema-bundles": "node scripts/build-schema-bundles.js",
    "check:examples": "node scripts/check-example-contracts.js",
    "check:api-examples": "node scripts/check-api-examples.js",
    "check:api-schemas": "node scripts/check-api-schemas.js",
    "check:type-projections": "tsc --noEmit --pretty false",
    "check:package-surface": "npm run build:projections && node scripts/check-package-surface.js",
    "check:package-install": "node scripts/check-package-install.js",
    "check:openapi-codegen": "node scripts/check-openapi-codegen.js",
    "check:openapi-coherence": "node scripts/check-openapi-coherence.js",
    "check:raw-capsules": "node scripts/check-raw-capsules.js",
    "check:reference-pack": "node scripts/check-reference-pack.js",
    "check:schema-bundles": "node scripts/check-schema-bundles.js",
    "check:schema-recipes": "node scripts/check-schema-recipes.js",
    "check:archive-recipes": "node scripts/check-archive-recipes.js",
    "check:invalid-archive-examples": "node scripts/check-invalid-archive-examples.js",
    "check:invalid-examples": "node scripts/check-invalid-examples.js",
    "check:invalid-api-examples": "node scripts/check-invalid-api-examples.js",
    "check:invalid-client-recipe-index-examples": "node scripts/check-invalid-client-recipe-index-examples.js",
    "check:integrity-recipes": "node scripts/check-integrity-recipes.js",
    "check:python-recipes": "node scripts/check-python-recipes.js",
    "check:example-coverage": "node scripts/check-example-coverage.js",
    "check:boundary-map": "node scripts/check-boundary-map.js",
    "check:client-recipes": "node scripts/check-client-recipes.js",
    "check:community-health": "node scripts/check-community-health.js",
    "check:github-operations": "node scripts/check-github-operations.js",
    "check:maintenance-model": "node scripts/check-maintenance-model.js",
    "check:change-control": "node scripts/check-change-control.js",
    "check:ownership-map": "node scripts/check-ownership-map.js",
    "check:dependency-graph": "node scripts/check-dependency-graph.js",
    "check:assurance-case": "node scripts/check-assurance-case.js",
    "check:update-coherence": "node scripts/check-update-coherence.js",
    "check:limitations-register": "node scripts/check-limitations-register.js",
    "check:evidence-timeline": "node scripts/check-evidence-timeline.js",
    "check:review-scorecard": "node scripts/check-review-scorecard.js",
    "check:verification-matrix": "node scripts/check-verification-matrix.js",
    "check:audience-paths": "node scripts/check-audience-paths.js",
    "check:evidence-strength": "node scripts/check-evidence-strength.js",
    "check:adoption-readiness": "node scripts/check-adoption-readiness.js",
    "check:freshness": "node scripts/check-freshness.js",
    "check:evidence-gaps": "node scripts/check-evidence-gaps.js",
    "check:program-fit": "node scripts/check-program-fit.js",
    "check:publication-readiness": "node scripts/check-publication-readiness.js",
    "check:repository-identity": "node scripts/check-repository-identity.js",
    "check:capability-matrix": "node scripts/check-capability-matrix.js",
    "check:docs": "node scripts/check-doc-links.js",
    "check:catalog": "node scripts/check-contract-catalog.js",
    "check:evaluation-packet": "node scripts/check-evaluation-packet.js",
    "check:failure-model": "node scripts/check-failure-model.js",
    "check:traceability": "node scripts/check-traceability-matrix.js",
    "check:portability": "node scripts/check-portability-profile.js",
    "check:project-profile": "node scripts/check-project-profile.js",
    "check:surface": "node scripts/check-surface-coherence.js",
    "check:release": "node scripts/check-release-metadata.js",
    "verify:repo": "npm run audit:public-surface && npm run check:examples && npm run check:api-examples && npm run check:api-schemas && npm run check:type-projections && npm run check:package-surface && npm run check:package-install && npm run check:openapi-codegen && npm run check:raw-capsules && npm run check:reference-pack && npm run check:openapi-coherence && npm run check:schema-bundles && npm run check:schema-recipes && npm run check:archive-recipes && npm run check:invalid-archive-examples && npm run check:invalid-examples && npm run check:invalid-api-examples && npm run check:invalid-client-recipe-index-examples && npm run check:integrity-recipes && npm run check:python-recipes && npm run check:example-coverage && npm run check:boundary-map && npm run check:client-recipes && npm run check:community-health && npm run check:github-operations && npm run check:maintenance-model && npm run check:change-control && npm run check:ownership-map && npm run check:dependency-graph && npm run check:assurance-case && npm run check:update-coherence && npm run check:limitations-register && npm run check:evidence-timeline && npm run check:review-scorecard && npm run check:verification-matrix && npm run check:audience-paths && npm run check:evidence-strength && npm run check:adoption-readiness && npm run check:freshness && npm run check:ecosystem-value && npm run check:decision-log && npm run check:evidence-gaps && npm run check:program-fit && npm run check:publication-readiness && npm run check:repository-identity && npm run check:docs && npm run check:catalog && npm run check:evaluation-packet && npm run check:failure-model && npm run check:traceability && npm run check:portability && npm run check:project-profile && npm run check:capability-matrix && npm run check:surface && npm run check:release",
    "check:ecosystem-value": "node scripts/check-ecosystem-value.js",
    "check:decision-log": "node scripts/check-decision-log.js",
    "prepack": "npm run build:projections"
  }
}
