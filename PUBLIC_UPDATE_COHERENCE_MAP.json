{
  "version": "0.1.0",
  "reviewed_at": "2026-03-26",
  "sync_groups": [
    {
      "id": "front-door-and-reviewer-path",
      "summary": "Front-door docs and reviewer shortcuts should move together when the public reading path or strongest public summaries change.",
      "change_triggers": [
        "new reviewer-facing machine-readable surface",
        "reordered fast-review path",
        "changed public orientation or quickstart flow"
      ],
      "required_surfaces": [
        "README.md",
        "QUICKSTART.md",
        "docs/reviewer-guide.md",
        "docs/evaluation-packet.md",
        "PUBLIC_PROJECT_PROFILE.json",
        "PUBLIC_EVALUATION_PACKET.json"
      ],
      "verify_commands": [
        "npm run check:project-profile",
        "npm run check:evaluation-packet",
        "npm run check:update-coherence"
      ]
    },
    {
      "id": "contracts-examples-and-teaching",
      "summary": "Contracts, examples, and teaching docs should move together when schema, OpenAPI, API envelopes, or public examples change meaning.",
      "change_triggers": [
        "schema field change",
        "OpenAPI route or payload change",
        "example or client-recipe semantics change"
      ],
      "required_surfaces": [
        "schemas/capsule-schema.json",
        "schemas/validator-api-envelopes.schema.json",
        "openapi/validate.openapi.json",
        "docs/api-envelopes.md",
        "docs/route-reference.md",
        "PUBLIC_EXAMPLE_COVERAGE.json",
        "PUBLIC_FAILURE_MODEL.json"
      ],
      "verify_commands": [
        "npm run check:api-examples",
        "npm run check:api-schemas",
        "npm run check:example-coverage",
        "npm run check:failure-model",
        "npm run check:update-coherence"
      ]
    },
    {
      "id": "release-provenance-and-sync-evidence",
      "summary": "Release-facing and provenance artifacts should move together when public files are added, removed, reclassified, or reverified.",
      "change_triggers": [
        "public file added or removed",
        "catalog membership changed",
        "verification stack changed",
        "release evidence refreshed"
      ],
      "required_surfaces": [
        "SOURCE_MANIFEST.json",
        "PUBLIC_CONTRACT_CATALOG.json",
        "PUBLIC_RELEASE_METADATA.json",
        "PUBLIC_RELEASE_REVIEW.md",
        "CHANGELOG.md",
        "PUBLIC_UPDATE_COHERENCE_MAP.json"
      ],
      "verify_commands": [
        "npm run audit:public-surface",
        "npm run check:catalog",
        "npm run check:release",
        "npm run check:update-coherence"
      ]
    },
    {
      "id": "governance-and-summary-layers",
      "summary": "Governance summaries should move together when reviewer claims, maintenance posture, ownership, dependency order, assurance posture, or traceability change materially.",
      "change_triggers": [
        "new reviewer-facing claim",
        "changed maintenance or change-control posture",
        "changed ownership, dependency, or assurance summaries"
      ],
      "required_surfaces": [
        "PUBLIC_MAINTENANCE_MODEL.json",
        "PUBLIC_CHANGE_CONTROL_MODEL.json",
        "PUBLIC_OWNERSHIP_MAP.json",
        "PUBLIC_DEPENDENCY_GRAPH.json",
        "PUBLIC_ASSURANCE_CASE.json",
        "PUBLIC_TRACEABILITY_MATRIX.json",
        "PUBLIC_CAPABILITY_MATRIX.json"
      ],
      "verify_commands": [
        "npm run check:maintenance-model",
        "npm run check:change-control",
        "npm run check:dependency-graph",
        "npm run check:assurance-case",
        "npm run check:traceability",
        "npm run check:capability-matrix",
        "npm run check:update-coherence"
      ]
    }
  ],
  "non_claims": [
    "This file does not describe every internal build dependency or private rollout sequence in the upstream N1Hub runtime.",
    "This file does not replace the stronger release, provenance, contract, example, or reviewer-evidence surfaces it references."
  ],
  "review_commands": [
    "npm run check:update-coherence",
    "npm run verify:repo"
  ]
}
