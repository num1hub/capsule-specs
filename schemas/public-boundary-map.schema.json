{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n1hub/specs/schemas/public-boundary-map.schema.json",
  "title": "N1Hub Specs Public Boundary Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "global_rules",
    "published_boundaries",
    "deferred_domains"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "global_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "published_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/publishedBoundary"
      }
    },
    "deferred_domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/deferredDomain"
      }
    }
  },
  "$defs": {
    "publishedBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "strongest_surfaces",
        "source_capsules",
        "verify_commands"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "strongest_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "source_capsules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "verify_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "deferredDomain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "summary",
        "reason"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "const": "deferred"
        },
        "summary": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
