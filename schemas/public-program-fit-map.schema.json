{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n1hub/specs/schemas/public-program-fit-map.schema.json",
  "title": "Public Program Fit Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "purpose",
    "fit_families",
    "non_claims",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "fit_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary",
          "why_it_matters",
          "strongest_current_surfaces",
          "bounded_fit_claims",
          "review_commands",
          "bounded_non_claims"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "strongest_current_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "bounded_fit_claims": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "review_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "bounded_non_claims": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
