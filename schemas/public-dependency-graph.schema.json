{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n1hub/specs/schemas/public-dependency-graph.schema.json",
  "title": "PublicDependencyGraph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "nodes",
    "reading_paths",
    "non_claims",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "reading_paths": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/readingPath"
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "role",
        "depends_on",
        "verify_commands"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verify_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "readingPath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "audience",
        "steps"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
