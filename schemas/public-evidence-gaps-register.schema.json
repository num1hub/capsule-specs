{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n1hub/specs/schemas/public-evidence-gaps-register.schema.json",
  "title": "Public Evidence Gaps Register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "purpose",
    "gap_families",
    "non_claims",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "gap_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary",
          "why_gap_exists",
          "strongest_current_surfaces",
          "missing_or_manual_evidence",
          "next_public_hardening_steps",
          "verify_commands",
          "bounded_non_claims"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "why_gap_exists": {
            "type": "string"
          },
          "strongest_current_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "missing_or_manual_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "next_public_hardening_steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "verify_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "bounded_non_claims": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
