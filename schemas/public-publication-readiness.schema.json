{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/num1hub/capsule-specs/schemas/public-publication-readiness.schema.json",
  "title": "Public Publication Readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "purpose",
    "readiness_families",
    "non_claims",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "readiness_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "summary",
          "why_it_matters",
          "strongest_current_surfaces",
          "publish_checks",
          "bounded_non_claims"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "ready",
              "deferred"
            ]
          },
          "summary": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "strongest_current_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "publish_checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "bounded_non_claims": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
