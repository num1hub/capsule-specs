{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/num1hub/capsule-specs/schemas/public-update-coherence-map.schema.json",
  "title": "Public Update Coherence Map",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "sync_groups",
    "non_claims",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "sync_groups": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary",
          "change_triggers",
          "required_surfaces",
          "verify_commands"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "change_triggers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "required_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "verify_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
