{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/num1hub/capsule-specs/schemas/public-repository-identity.schema.json",
  "title": "Public Repository Identity",
  "description": "Machine-readable repository identity and publication-alignment surface for the public specs repository.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "repository",
    "package",
    "release",
    "identity_claims",
    "bounded_non_claims",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "reviewed_at": {
      "type": "string",
      "minLength": 1
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "name",
        "slug",
        "canonical_repo_url",
        "canonical_git_https",
        "project_homepage",
        "default_branch",
        "visibility"
      ],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 },
        "canonical_repo_url": { "type": "string", "minLength": 1 },
        "canonical_git_https": { "type": "string", "minLength": 1 },
        "project_homepage": { "type": "string", "minLength": 1 },
        "default_branch": { "type": "string", "minLength": 1 },
        "visibility": { "type": "string", "minLength": 1 }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "license"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "license": { "type": "string", "minLength": 1 }
      }
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latest_tag",
        "latest_release_url"
      ],
      "properties": {
        "latest_tag": { "type": "string", "minLength": 1 },
        "latest_release_url": { "type": "string", "minLength": 1 }
      }
    },
    "identity_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "bounded_non_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
