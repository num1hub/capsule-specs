{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n1hub/specs/schemas/archive-bundle.schema.json",
  "title": "Archive Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundleId",
    "sourcePolicyId",
    "createdAt",
    "sourceRegion",
    "tenantScope",
    "compression",
    "encryption",
    "exportEvidenceId",
    "manifest",
    "replay"
  ],
  "properties": {
    "bundleId": {
      "type": "string",
      "minLength": 1
    },
    "sourcePolicyId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceRegion": {
      "type": "string",
      "minLength": 1
    },
    "tenantScope": {
      "type": "string",
      "enum": [
        "single-tenant",
        "multi-tenant",
        "regional"
      ]
    },
    "compression": {
      "type": "string",
      "enum": [
        "none",
        "gzip",
        "zstd"
      ]
    },
    "encryption": {
      "type": "string",
      "enum": [
        "none",
        "age",
        "kms-envelope"
      ]
    },
    "exportEvidenceId": {
      "type": "string",
      "minLength": 1
    },
    "manifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/manifestEntry"
      }
    },
    "replay": {
      "$ref": "#/$defs/replayGuard"
    }
  },
  "$defs": {
    "manifestEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entryId",
        "contentClass",
        "sha256",
        "bytes",
        "tenantScoped",
        "redacted"
      ],
      "properties": {
        "entryId": {
          "type": "string",
          "minLength": 1
        },
        "capsuleId": {
          "type": "string"
        },
        "contentClass": {
          "type": "string",
          "enum": [
            "capsules",
            "activity",
            "artifacts",
            "audit"
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "tenantScoped": {
          "type": "boolean"
        },
        "redacted": {
          "type": "boolean"
        }
      }
    },
    "replayGuard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "replayMode",
        "validatorRequired",
        "tenantBoundaryRequired",
        "policyPackRequired",
        "duplicateStrategy"
      ],
      "properties": {
        "replayMode": {
          "type": "string",
          "enum": [
            "dry-run",
            "validate-only",
            "merge",
            "replace"
          ]
        },
        "validatorRequired": {
          "type": "boolean"
        },
        "tenantBoundaryRequired": {
          "type": "boolean"
        },
        "policyPackRequired": {
          "type": "boolean"
        },
        "duplicateStrategy": {
          "type": "string",
          "enum": [
            "skip",
            "reject",
            "version"
          ]
        }
      }
    }
  }
}
