{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/num1hub/capsule-specs/schemas/validator-api-envelopes.bundle.json",
  "title": "N1Hub Validator API Envelopes",
  "description": "Single-file public JSON Schema bundle for validator-facing request and response envelopes published in the N1Hub specs repository.",
  "$defs": {
    "validationOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skipG16": {
          "type": "boolean"
        },
        "allowRefutes": {
          "type": "boolean"
        },
        "existingIds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validatorIssue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "path",
        "message"
      ],
      "properties": {
        "gate": {
          "type": "string",
          "pattern": "^G\\d{2}$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "warningItem": {
      "type": "object"
    },
    "validateSingleRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capsule",
        "options",
        "autoFix"
      ],
      "properties": {
        "capsule": {
          "$ref": "#/$defs/capsule"
        },
        "options": {
          "$ref": "#/$defs/validationOptions"
        },
        "autoFix": {
          "type": "boolean"
        }
      }
    },
    "validateBatchRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capsules",
        "options"
      ],
      "properties": {
        "capsules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/capsule"
          }
        },
        "options": {
          "$ref": "#/$defs/validationOptions"
        }
      }
    },
    "validateFixRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capsule",
        "options"
      ],
      "properties": {
        "capsule": {
          "$ref": "#/$defs/capsule"
        },
        "options": {
          "$ref": "#/$defs/validationOptions"
        }
      }
    },
    "validatePassResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid",
        "errors",
        "warnings",
        "computedHash",
        "appliedFixes"
      ],
      "properties": {
        "valid": {
          "const": true
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validatorIssue"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warningItem"
          }
        },
        "computedHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        },
        "appliedFixes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "validateFailResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid",
        "errors",
        "warnings",
        "computedHash"
      ],
      "properties": {
        "valid": {
          "const": false
        },
        "errors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/validatorIssue"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warningItem"
          }
        },
        "computedHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        }
      }
    },
    "validateBatchResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capsuleId",
        "valid",
        "errors",
        "warnings",
        "computedHash"
      ],
      "properties": {
        "capsuleId": {
          "type": "string",
          "minLength": 1
        },
        "valid": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validatorIssue"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warningItem"
          }
        },
        "computedHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        }
      }
    },
    "validateBatchResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "results"
      ],
      "properties": {
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "total",
            "valid",
            "invalid",
            "withWarnings",
            "totalErrors",
            "totalWarnings"
          ],
          "properties": {
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "valid": {
              "type": "integer",
              "minimum": 0
            },
            "invalid": {
              "type": "integer",
              "minimum": 0
            },
            "withWarnings": {
              "type": "integer",
              "minimum": 0
            },
            "totalErrors": {
              "type": "integer",
              "minimum": 0
            },
            "totalWarnings": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "results": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/validateBatchResult"
          }
        }
      }
    },
    "validateFixResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "valid",
        "errors",
        "warnings",
        "computedHash",
        "fixedCapsule"
      ],
      "properties": {
        "valid": {
          "const": true
        },
        "errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/validatorIssue"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warningItem"
          }
        },
        "computedHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        },
        "fixedCapsule": {
          "$ref": "#/$defs/capsule"
        }
      }
    },
    "gateDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description",
        "severity",
        "autoFixable"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^G\\d{2}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "error",
            "warning"
          ]
        },
        "autoFixable": {
          "type": "boolean"
        }
      }
    },
    "gatesResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gates"
      ],
      "properties": {
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/gateDescriptor"
          }
        }
      }
    },
    "statsRecentItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capsuleId",
        "valid",
        "timestamp"
      ],
      "properties": {
        "capsuleId": {
          "type": "string",
          "minLength": 1
        },
        "valid": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "statsTrendItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bucket",
        "passed",
        "failed"
      ],
      "properties": {
        "bucket": {
          "type": "string",
          "minLength": 1
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "statsGateItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "count"
      ],
      "properties": {
        "gate": {
          "type": "string",
          "pattern": "^G\\d{2}$"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "statsResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total",
        "passed",
        "failed",
        "warned",
        "passRate",
        "recent",
        "trend",
        "gates"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "warned": {
          "type": "integer",
          "minimum": 0
        },
        "passRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "recent": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statsRecentItem"
          }
        },
        "trend": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statsTrendItem"
          }
        },
        "gates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/statsGateItem"
          }
        }
      }
    },
    "simpleErrorResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error"
      ],
      "properties": {
        "error": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "capsule": {
      "title": "CapsuleOS Capsule",
      "description": "Public JSON Schema for the five-element capsule shape used by N1Hub and CapsuleOS.",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata",
        "core_payload",
        "neuro_concentrate",
        "recursive_layer",
        "integrity_sha3_512"
      ],
      "properties": {
        "metadata": {
          "type": "object",
          "description": "Identity, lifecycle state, timestamps, and semantic hash.",
          "additionalProperties": true,
          "required": [
            "capsule_id",
            "type",
            "subtype",
            "status",
            "version",
            "semantic_hash"
          ],
          "properties": {
            "capsule_id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "enum": [
                "foundation",
                "concept",
                "operations",
                "physical_object",
                "project"
              ]
            },
            "subtype": {
              "type": "string",
              "enum": [
                "atomic",
                "hub"
              ]
            },
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "active",
                "frozen",
                "archived",
                "legacy",
                "sovereign",
                "quarantined"
              ]
            },
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            },
            "author": {
              "type": "string"
            },
            "created_at": {
              "type": "string"
            },
            "updated_at": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "semantic_hash": {
              "type": "string",
              "pattern": "^(?:[a-z0-9]+-){7}[a-z0-9]+$"
            },
            "source": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "uri": {
                  "type": "string"
                },
                "sha256": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              }
            }
          }
        },
        "core_payload": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "content_type",
            "content"
          ],
          "properties": {
            "content_type": {
              "type": "string",
              "description": "Preferred values are markdown, json, or text; validator-compatible runtimes may support additional values."
            },
            "content": {
              "type": "string"
            },
            "truncation_note": {
              "type": "string"
            }
          }
        },
        "neuro_concentrate": {
          "$ref": "#/$defs/neuroConcentrate"
        },
        "recursive_layer": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "links"
          ],
          "properties": {
            "links": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "target_id",
                  "relation_type"
                ],
                "properties": {
                  "target_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "relation_type": {
                    "type": "string",
                    "enum": [
                      "supports",
                      "contradicts",
                      "extends",
                      "derived_from",
                      "depends_on",
                      "references",
                      "duplicates",
                      "implements",
                      "part_of"
                    ]
                  }
                }
              }
            },
            "epistemic_ledger": {
              "type": "array",
              "items": {}
            }
          }
        },
        "integrity_sha3_512": {
          "type": "string",
          "pattern": "^[a-f0-9]{128}$"
        }
      }
    },
    "neuroConcentrate": {
      "title": "CapsuleOS Neuro Concentrate",
      "description": "Public JSON Schema for the semantic summary layer of a capsule.",
      "type": "object",
      "additionalProperties": true,
      "required": [
        "summary",
        "confidence_vector",
        "keywords",
        "semantic_hash"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "description": "Validator policy expects 70 to 160 words."
        },
        "keywords": {
          "type": "array",
          "minItems": 5,
          "maxItems": 15,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "confidence_vector": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "extraction",
            "synthesis",
            "linking",
            "provenance_coverage",
            "validation_score",
            "contradiction_pressure"
          ],
          "properties": {
            "extraction": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "synthesis": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "linking": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "provenance_coverage": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "validation_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "contradiction_pressure": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "semantic_hash": {
          "type": "string",
          "pattern": "^(?:[a-z0-9]+-){7}[a-z0-9]+$"
        }
      }
    }
  }
}
