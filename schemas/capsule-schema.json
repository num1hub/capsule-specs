{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n1hub/specs/schemas/capsule-schema.json",
  "title": "CapsuleOS Capsule",
  "description": "Public JSON Schema for the five-element capsule shape used by N1Hub and CapsuleOS.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "core_payload",
    "neuro_concentrate",
    "recursive_layer",
    "integrity_sha3_512"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Identity, lifecycle state, timestamps, and semantic hash.",
      "additionalProperties": true,
      "required": [
        "capsule_id",
        "type",
        "subtype",
        "status",
        "version",
        "semantic_hash"
      ],
      "properties": {
        "capsule_id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "foundation",
            "concept",
            "operations",
            "physical_object",
            "project"
          ]
        },
        "subtype": {
          "type": "string",
          "enum": [
            "atomic",
            "hub"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "frozen",
            "archived",
            "legacy",
            "sovereign",
            "quarantined"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "author": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "semantic_hash": {
          "type": "string",
          "pattern": "^(?:[a-z0-9]+-){7}[a-z0-9]+$"
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "uri": {
              "type": "string"
            },
            "sha256": {
              "type": "string"
            },
            "type": {
              "type": "string"
            }
          }
        }
      }
    },
    "core_payload": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "content_type",
        "content"
      ],
      "properties": {
        "content_type": {
          "type": "string",
          "description": "Preferred values are markdown, json, or text; validator-compatible runtimes may support additional values."
        },
        "content": {
          "type": "string"
        },
        "truncation_note": {
          "type": "string"
        }
      }
    },
    "neuro_concentrate": {
      "$ref": "./neuro-concentrate.schema.json"
    },
    "recursive_layer": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "links"
      ],
      "properties": {
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "target_id",
              "relation_type"
            ],
            "properties": {
              "target_id": {
                "type": "string",
                "minLength": 1
              },
              "relation_type": {
                "type": "string",
                "enum": [
                  "supports",
                  "contradicts",
                  "extends",
                  "derived_from",
                  "depends_on",
                  "references",
                  "duplicates",
                  "implements",
                  "part_of"
                ]
              }
            }
          }
        },
        "epistemic_ledger": {
          "type": "array",
          "items": {}
        }
      }
    },
    "integrity_sha3_512": {
      "type": "string",
      "pattern": "^[a-f0-9]{128}$"
    }
  }
}
