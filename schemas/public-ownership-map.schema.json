{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n1hub/specs/schemas/public-ownership-map.schema.json",
  "title": "PublicOwnershipMap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "ownership_groups",
    "non_claims",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "ownership_groups": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/ownershipGroup"
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "ownershipGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "public_owner",
        "stronger_sources",
        "owned_artifacts",
        "stability",
        "verify_commands"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "public_owner": {
          "type": "string"
        },
        "stronger_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "owned_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "stability": {
          "type": "string"
        },
        "verify_commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
