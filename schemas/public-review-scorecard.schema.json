{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/num1hub/capsule-specs/schemas/public-review-scorecard.schema.json",
  "title": "Public Review Scorecard",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "purpose",
    "criteria",
    "important_limits",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "criteria": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "question",
          "status",
          "summary",
          "strongest_surfaces",
          "review_commands"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "question": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "bounded"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "strongest_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "important_limits": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
