{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n1hub/specs/schemas/public-evidence-timeline.schema.json",
  "title": "Public Evidence Timeline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "purpose",
    "milestones",
    "review_commands"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "milestones": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "order",
          "date",
          "commit",
          "title",
          "focus",
          "strongest_surfaces",
          "review_commands",
          "maintenance_signal"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "date": {
            "type": "string",
            "format": "date"
          },
          "commit": {
            "type": "string",
            "pattern": "^[0-9a-f]{7,40}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "focus": {
            "type": "string",
            "minLength": 1
          },
          "strongest_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "maintenance_signal": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
