{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/num1hub/capsule-specs/schemas/public-traceability-matrix.schema.json",
  "title": "Public Traceability Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "reviewed_at",
    "traces",
    "non_claims",
    "review_commands"
  ],
  "properties": {
    "version": { "type": "string" },
    "reviewed_at": { "type": "string" },
    "traces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "claim",
          "audiences",
          "strongest_surfaces",
          "supporting_surfaces",
          "verify_commands"
        ],
        "properties": {
          "id": { "type": "string" },
          "claim": { "type": "string" },
          "audiences": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "strongest_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "supporting_surfaces": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "verify_commands": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "review_commands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
